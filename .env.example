# ── Companies House ────────────────────────────────────────────────────────
# Get your key at: https://developer.company-information.service.gov.uk/
CH_API_KEY=your_companies_house_api_key_here

# ── Supabase ───────────────────────────────────────────────────────────────
# Supabase project: Settings > Database > Connection string > URI
# Use the "Session mode" URI (port 5432), not the transaction pooler
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-PROJECT-REF].supabase.co:5432/postgres

# Supabase service role key — Settings > API > service_role (secret)
# This bypasses Row Level Security so the pipeline can write freely
SUPABASE_SERVICE_KEY=your_service_role_key_here
